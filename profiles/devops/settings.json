{
  "permissions": {
    "allow": [
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(terraform fmt*)",
      "Bash(aws sts *)",
      "Bash(aws s3 ls *)",
      "Bash(gcloud *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(kubectl delete*)",
      "Bash(docker system prune*)",
      "Bash(aws s3 rm *)"
    ]
  }
}
